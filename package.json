{
  "name": "forgeax-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ForgeaX reusable orchestration layer: R2 compose/resolve/toWire/checkTool, session/scheduler/tree, soul (digital life), kits, llm, kernel adaptors, ledger, HTTP api routers, ws, builtin kits/personas.",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./brand": "./src/brand/index.ts",
    "./cli-providers": "./src/cli-providers/index.ts",
    "./*": ["./src/*.ts", "./src/*/index.ts"]
  },
  "bin": {
    "forgeax-pack": "./bin/forgeax-pack",
    "forge": "./bin/forge"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint:boundaries": "depcruise --config .dependency-cruiser.cjs src"
  },
  "dependencies": {
    "@forgeax/agent-host": "workspace:*",
    "@forgeax/agent-runtime": "workspace:*",
    "@forgeax/platform-io": "workspace:*",
    "@forgeax/types": "workspace:*",
    "@ag-ui/core": "^0.0.53",
    "@google/genai": "^1.0.0",
    "chokidar": "^4.0.0",
    "hono": "^4.6.0",
    "minimatch": "^10.2.5",
    "sharp": "^0.34.5",
    "yaml": "^2.8.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^20.0.0",
    "dependency-cruiser": "^17.4.3",
    "typescript": "^5.6.3"
  }
}
