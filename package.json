{
  "name": "forgeax-cli",
  "version": "1.3.0",
  "type": "module",
  "description": "ForgeaX agent runtime kernel \u2014 multi-agent orchestration runtime hosted in-process by @forgeax/server.",
  "bin": {
    "forgeax": "./bin/forgeax"
  },
  "engines": {
    "node": ">=22"
  },
  "imports": {
    "#src/*": "./src/*",
    "#capabilities/*": "./capabilities/*"
  },
  "scripts": {
    "start": "tsx src/main.ts",
    "dev": "tsx watch --ignore team --ignore debug.log src/main.ts",
    "ctl": "tsx src/ctl-command/gateway-ctl/index.ts",
    "wechat": "tsx src/ctl-command/wechat.ts",
    "ink-renderer": "tsx src/ctl-command/ink-renderer.ts",
    "engine-channel": "tsx src/ctl-command/engine-channel.ts",
    "ui:dev": "cd ui && pnpm dev",
    "ui:build": "cd ui && pnpm build"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.3.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.14",
    "@types/react-reconciler": "^0.33.0",
    "@types/stack-utils": "^2.0.3",
    "ansi-styles": "^6.2.3",
    "auto-bind": "^5.0.1",
    "better-sqlite3": "^12.8.0",
    "bidi-js": "^1.0.3",
    "chalk": "^5.6.2",
    "cli-boxes": "^4.0.1",
    "cli-cursor": "^5.0.0",
    "code-excerpt": "^4.0.0",
    "discord.js": "^14.26.2",
    "emoji-regex": "^10.6.0",
    "fast-glob": "^3.3.3",
    "get-east-asian-width": "^1.5.0",
    "indent-string": "^5.0.0",
    "lodash-es": "^4.18.1",
    "marked": "^17.0.5",
    "mime-types": "^3.0.2",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.4",
    "react-reconciler": "^0.31.0",
    "restore-cursor": "^5.1.0",
    "semver": "^7.7.4",
    "sharp": "^0.34.5",
    "signal-exit": "^4.1.0",
    "slice-ansi": "^8.0.0",
    "stack-utils": "^2.0.6",
    "string-width": "^8.2.0",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^4.4.0",
    "ts-lsp-client": "1.0.3",
    "type-fest": "^5.5.0",
    "typescript-language-server": "^5.1.3",
    "usehooks-ts": "^3.1.1",
    "widest-line": "^6.0.0",
    "wrap-ansi": "^10.0.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "_comment": "pnpm 11+ ignores this field; canonical config now lives in pnpm-workspace.yaml. Kept for pnpm 9/10 back-compat only.",
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "protobufjs",
      "sharp",
      "@google/genai"
    ]
  }
}