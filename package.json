{
  "name": "forgeax-cli",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "description": "ForgeaX reusable orchestration layer: R2 compose/resolve/toWire/checkTool, session/scheduler/tree, soul (digital life), kits, llm, kernel adaptors, ledger, HTTP api routers, ws, builtin kits/personas.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./kernel/forgeax-core-kernel": {
      "types": "./dist/kernel/forgeax-core-kernel.d.ts",
      "import": "./dist/kernel/forgeax-core-kernel.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build.mjs",
    "pack:tgz": "npm pack",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint:boundaries": "depcruise --config .dependency-cruiser.cjs src",
    "check:business-agnostic": "bun scripts/check-business-agnostic.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "chokidar": "^4.0.0",
    "hono": "^4.6.0",
    "minimatch": "^10.2.5",
    "sharp": "^0.34.5",
    "yaml": "^2.8.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^20.0.0",
    "dependency-cruiser": "^17.4.3",
    "typescript": "^5.6.3"
  }
}
